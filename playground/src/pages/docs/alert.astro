---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
import { Alert, Typography } from '@rubengvillar/design-system-astro';

// 1. Alerta por defecto
const defaultCode = `<Alert title="Información del sistema">
  <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
  Una nueva actualización de las políticas de privacidad está disponible.
</Alert>`;

// 2. Alerta de Error
const errorCode = `<Alert variant="error" title="Error de conexión">
  <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
  No se pudo guardar tu configuración. Por favor, inténtalo de nuevo.
</Alert>`;

// 3. Alerta de Éxito
const successCode = `<Alert variant="success" title="¡Operación exitosa!">
  <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
  Tus cambios han sido guardados correctamente en la base de datos.
</Alert>`;

// 4. Alerta de Advertencia (Warning)
const warningCode = `<Alert variant="warning" title="Atención requerida">
  <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
  Tu suscripción caducará en 3 días. Actualiza tu método de pago.
</Alert>`;

// 5. Alerta Dismissible (Cerrable)
const dismissibleCode = `<Alert variant="default" title="Notificación temporal" dismissible>
  <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
  Puedes cerrar este mensaje haciendo clic en la 'X' de la derecha.
</Alert>`;
---

<DocsLayout title="Alert">
  <Typography variant="lead" class="mb-8">
    Muestra un mensaje de llamada de atención (callout) para la atención del usuario.
  </Typography>

  <ComponentPreview title="Default (Información)" code={defaultCode}>
    <div class="w-full max-w-2xl">
      <Alert title="Información del sistema">
        <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        Una nueva actualización de las políticas de privacidad está disponible.
      </Alert>
    </div>
  </ComponentPreview>

  <ComponentPreview title="Error (Destructivo)" code={errorCode}>
    <div class="w-full max-w-2xl">
      <Alert variant="error" title="Error de conexión">
        <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        No se pudo guardar tu configuración. Por favor, inténtalo de nuevo.
      </Alert>
    </div>
  </ComponentPreview>

  <ComponentPreview title="Success (Éxito)" code={successCode}>
    <div class="w-full max-w-2xl">
      <Alert variant="success" title="¡Operación exitosa!">
        <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Tus cambios han sido guardados correctamente en la base de datos.
      </Alert>
    </div>
  </ComponentPreview>

  <ComponentPreview title="Warning (Advertencia)" code={warningCode}>
    <div class="w-full max-w-2xl">
      <Alert variant="warning" title="Atención requerida">
        <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
        Tu suscripción caducará en 3 días. Actualiza tu método de pago.
      </Alert>
    </div>
  </ComponentPreview>

  <ComponentPreview title="Propiedad: Dismissible (Cerrable)" code={dismissibleCode}>
    <div class="w-full max-w-2xl">
      <Alert variant="default" title="Notificación temporal" dismissible>
        <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
        Puedes cerrar este mensaje haciendo clic en la 'X' de la derecha.
      </Alert>
    </div>
  </ComponentPreview>

</DocsLayout>