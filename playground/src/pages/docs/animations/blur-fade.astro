---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import { BlurFade, Image } from '@rubengvillar/design-system-astro';
---

<DocsLayout title="Blur Fade" description="Aparece elementos difuminados que se enfocan suavemente.">
  <section class="space-y-6">
    <div>
      <p class="text-muted-foreground mb-4">
        El componente <code>&lt;BlurFade /&gt;</code> revela contenido reduciendo su opacidad y desenfoque (blur) al entrar en pantalla. Aporta un efecto cinemático excelente para galerías e imágenes destacadas.
      </p>
    </div>

    <div class="space-y-4">
      <h3 class="text-xl font-bold">Ejemplos</h3>
      
      <div class="grid gap-4 md:grid-cols-2">
        <BlurFade delay={100} duration={1000} blurSize="12px">
          <div class="p-6 bg-primary/10 rounded-xl border border-primary/20 flex flex-col items-center justify-center min-h-[200px]">
            <span class="text-2xl font-bold text-primary">Contenido Difuminado</span>
          </div>
        </BlurFade>

        <BlurFade delay={300} duration={1000}>
          <div class="p-6 bg-secondary/20 rounded-xl border border-secondary/30 flex flex-col items-center justify-center min-h-[200px]">
            <span class="text-2xl font-bold text-secondary">Aparece después</span>
          </div>
        </BlurFade>
      </div>
    </div>

    <div class="space-y-4 mt-8">
      <h3 class="text-xl font-bold">Propiedades (Props)</h3>
      <div class="relative w-full overflow-auto">
        <table class="w-full caption-bottom text-sm border-collapse border">
          <thead class="[&_tr]:border-b bg-muted/50">
            <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground border-r">Propiedad</th>
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground border-r">Tipo</th>
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground border-r">Por defecto</th>
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Descripción</th>
            </tr>
          </thead>
          <tbody class="[&_tr:last-child]:border-0">
            <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
              <td class="p-4 align-middle border-r"><code>delay</code></td>
              <td class="p-4 align-middle border-r"><code>number</code></td>
              <td class="p-4 align-middle border-r"><code>0</code></td>
              <td class="p-4 align-middle">Retraso en milisegundos.</td>
            </tr>
            <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
              <td class="p-4 align-middle border-r"><code>duration</code></td>
              <td class="p-4 align-middle border-r"><code>number</code></td>
              <td class="p-4 align-middle border-r"><code>700</code></td>
              <td class="p-4 align-middle">Duración de la animación en ms.</td>
            </tr>
            <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
              <td class="p-4 align-middle border-r"><code>blurSize</code></td>
              <td class="p-4 align-middle border-r"><code>string</code></td>
              <td class="p-4 align-middle border-r"><code>'8px'</code></td>
              <td class="p-4 align-middle">Cantidad de desenfoque inicial.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</DocsLayout>
