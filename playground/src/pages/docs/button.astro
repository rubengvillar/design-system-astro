---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
import { Button as ButtonComponent, Typography } from '@rubengvillar/design-system-astro';

// Definimos los fragmentos de código en variables para mantener el HTML limpio
const primaryCode = `<Button>
  Primary Button
</Button>`;

const secondaryCode = `<Button variant="secondary">
  Secondary Button
</Button>`;

const disabledCode = `<Button disabled>
  Disabled Button
</Button>`;
---

<DocsLayout title="Button">
  <Typography variant="lead" class="mb-8 text-muted-foreground">
    Desencadena una acción o un evento, como enviar un formulario o mostrar un diálogo.
  </Typography>

  <ComponentPreview title="Variante: Primary (Por defecto)" code={primaryCode}>
    <ButtonComponent>Primary Button</ButtonComponent>
  </ComponentPreview>

  <ComponentPreview title="Variante: Secondary" code={secondaryCode}>
    <ButtonComponent variant="secondary">Secondary Button</ButtonComponent>
  </ComponentPreview>

  <ComponentPreview title="Estados: Disabled" code={disabledCode}>
    <ButtonComponent disabled>Disabled Button</ButtonComponent>
  </ComponentPreview>

  <div class="mt-12 space-y-4">
    <h3 class="text-2xl font-semibold tracking-tight">Botón como Enlace (Polimórfico)</h3>
    <Typography variant="body" class="text-muted-foreground mb-4">
      El componente Astro acepta la propiedad <code>as</code>. Puedes usarlo como un enlace pasando <code>as="a"</code> y sus respectivos atributos como <code>href</code>.
    </Typography>
    <ComponentPreview title="Variante: Enlace" code={`<Button as="a" href="#">\n  Ir al inicio\n</Button>`}>
      <ButtonComponent as="a" href="#">Ir al inicio</ButtonComponent>
    </ComponentPreview>
  </div>

  <div class="mt-12 space-y-4">
    <h3 class="text-2xl font-semibold tracking-tight">Uso en React (ReactButton)</h3>
    <Typography variant="body" class="text-muted-foreground mb-4">
      Si necesitas interactividad del lado del cliente en un componente React (por ejemplo, usar <code>onClick</code>), Astro no permite inyectar componentes nativos dentro de React. Para ello, el sistema de diseño exporta una versión exacta hecha en React llamada <code>ReactButton</code>.
    </Typography>
    <div class="bg-muted p-4 rounded-md overflow-x-auto text-sm">
      <pre><code>{`import { ReactButton as Button } from '@rubengvillar/design-system-astro';

export default function LoginForm() {
  return (
    <Button onClick={() => alert('Hola')} className="w-full">
      Iniciar Sesión
    </Button>
  );
}`}</code></pre>
    </div>
  </div>

</DocsLayout>