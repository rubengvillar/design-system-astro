---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
import { Navbar, NavbarLink, Typography } from '@rubengvillar/design-system-astro';

// 1. Código del Navbar Básico
const basicCode = `<Navbar>
  <a href="/" slot="brand" class="font-bold text-xl tracking-tight">
    BrandLogo
  </a>
  
  <Fragment slot="links">
    <NavbarLink href="/features">Características</NavbarLink>
    <NavbarLink href="/pricing">Precios</NavbarLink>
    <NavbarLink href="/about">Nosotros</NavbarLink>
  </Fragment>
</Navbar>`;

// 2. Código con enlaces activos
const activeStateCode = `<Navbar>
  <a href="/" slot="brand" class="font-bold text-xl tracking-tight">
    Docs
  </a>
  <Fragment slot="links">
    <NavbarLink href="/">Inicio</NavbarLink>
    <NavbarLink href="/docs/navbar" isActive={true}>
      Componentes
    </NavbarLink>
    <NavbarLink href="/github">GitHub</NavbarLink>
  </Fragment>
</Navbar>`;
---

<DocsLayout title="Navbar & NavbarLink">
  <Typography variant="lead" class="mb-8 text-muted-foreground">
    Una cabecera de navegación responsiva que soporta marca, enlaces y estados activos automáticos.
  </Typography>

  <ComponentPreview title="Navegación Básica" code={basicCode}>
    {/* Contenedor que simula una ventana de navegador para que el Navbar no se escape */}
    <div class="w-full flex flex-col rounded-xl border bg-background overflow-hidden shadow-sm">
      <Navbar>
        <a href="#home" slot="brand" class="font-bold text-xl tracking-tight">
          BrandLogo
        </a>
        <Fragment slot="links">
          <NavbarLink href="#features">Características</NavbarLink>
          <NavbarLink href="#pricing">Precios</NavbarLink>
          <NavbarLink href="#about">Nosotros</NavbarLink>
        </Fragment>
      </Navbar>
      
      {/* Falso contenido de página para dar contexto */}
      <div class="flex-1 bg-muted/30 p-8 flex items-center justify-center min-h-[150px]">
        <p class="text-sm text-muted-foreground">Contenido de la página</p>
      </div>
    </div>
  </ComponentPreview>

  <ComponentPreview title="Estado Activo (Active State)" code={activeStateCode}>
    <div class="w-full flex flex-col rounded-xl border bg-background overflow-hidden shadow-sm">
      <Navbar>
        <a href="#docs" slot="brand" class="font-bold text-xl tracking-tight">
          Docs
        </a>
        <Fragment slot="links">
          <NavbarLink href="#home">Inicio</NavbarLink>
          {/* Aquí forzamos el isActive para que se vea resaltado en la doc */}
          <NavbarLink href="#components" isActive={true}>Componentes</NavbarLink>
          <NavbarLink href="#github">GitHub</NavbarLink>
        </Fragment>
      </Navbar>
      
      <div class="flex-1 bg-muted/30 p-8 flex items-center justify-center min-h-[150px]">
        <p class="text-sm text-muted-foreground">Viendo la sección de Componentes...</p>
      </div>
    </div>
  </ComponentPreview>

</DocsLayout>