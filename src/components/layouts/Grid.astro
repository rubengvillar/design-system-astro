---
import { classMerge } from "../../utils/classMerge";

interface Props {
  cols?: string | number; // Ej: "1 md:2 lg:3" o 3
  gap?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { 
  cols = "1 md:2", 
  gap = "md", 
  class: className 
} = Astro.props;

const gapStyles = {
  sm: 'gap-2',
  md: 'gap-4',
  lg: 'gap-8',
};

const getColsClasses = () => {
  if (typeof cols === 'number') return `grid-cols-${cols}`;
  
  const parts = cols.toString().split(' ');
  let classes = '';
  
  parts.forEach(part => {
    if (part.includes('md:')) {
      classes += ` md:grid-cols-${part.replace('md:', '')}`;
    } else if (part.includes('lg:')) {
      classes += ` lg:grid-cols-${part.replace('lg:', '')}`;
    } else {
      classes += ` grid-cols-${part}`;
    }
  });
  
  return classes.trim();
};
---

<div class={classMerge(
  "grid w-full",
  getColsClasses(),
  gapStyles[gap],
  className
)}>
  <slot />
</div>
