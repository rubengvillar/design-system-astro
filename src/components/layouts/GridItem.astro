---
interface Props {
  colSpan?: '1' | '2' | '3' | 'full';
  class?: string;
}

const { colSpan = '1', class: className } = Astro.props;

const spans = {
  '1': 'col-span-1',
  '2': 'col-span-2',
  '3': 'col-span-3',
  'full': 'col-span-full',
};
---

<div class:list={[spans[colSpan], className]}>
  <slot />
</div>
