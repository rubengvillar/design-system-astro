---
import type { HTMLAttributes } from 'astro/types';
import { classMerge } from '../../utils/classMerge';

interface Props extends HTMLAttributes<'div'> {
  size?: 'sm' | 'md' | 'lg' | 'xl';
  axis?: 'vertical' | 'horizontal';
}

const { size = 'md', axis = 'vertical', class: className, ...rest } = Astro.props;

// Mapeo explícito de clases completas de Tailwind para evitar purga
const verticalSizes = {
  sm: 'h-4',      // 1rem
  md: 'h-8',      // 2rem
  lg: 'h-16',     // 4rem
  xl: 'h-24',     // 6rem
};

const horizontalSizes = {
  sm: 'w-4',      // 1rem
  md: 'w-8',      // 2rem
  lg: 'w-16',     // 4rem
  xl: 'w-24',     // 6rem
};

const sizeClass = axis === 'vertical' ? verticalSizes[size] : horizontalSizes[size];
---

<div 
  aria-hidden="true"
  class={classMerge("shrink-0", sizeClass, className)} 
  {...rest} 
/>
