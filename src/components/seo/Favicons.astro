---
import type { FaviconItem } from './types';

interface Props {
  items: FaviconItem[];
  themeColor?: string;
}

const { items, themeColor } = Astro.props;

const resolveHref = (href: string): string => {
  if (href.startsWith('http') || href.startsWith('/')) return href;
  return `/${href}`;
};

const validateHref = (href: string): boolean => {
  if (href.startsWith('http')) return true;
  if (href.startsWith('/') && !href.includes('..')) return true;
  return false;
};
---

{items.map((item) => {
  if (!validateHref(item.href)) return null;
  return (
    <link
      rel={item.rel}
      type={item.type}
      href={resolveHref(item.href)}
      color={item.color}
      sizes={item.sizes}
      data-seo={`favicon-${item.rel}`}
    />
  );
})}
{themeColor && <meta name="theme-color" content={themeColor} data-seo="theme-color" />}
<slot />
<slot />