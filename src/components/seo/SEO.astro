---
import MetaTags from './MetaTags.astro';
import OpenGraph from './OpenGraph.astro';
import TwitterCard from './TwitterCard.astro';

interface Props {
  title: string;
  description: string;
  image?: string; // URL de la imagen para redes sociales
  canonicalURL?: string;
  type?: 'website' | 'article' | 'profile' | 'book';
  twitterCardType?: 'summary' | 'summary_large_image' | 'app' | 'player';
}

const { 
  title, 
  description, 
  image = '/og-image.png', // Ruta por defecto a tu imagen de preview
  canonicalURL = Astro.url.href,
  type = 'website',
  twitterCardType = 'summary_large_image'
} = Astro.props;
---

<MetaTags 
  title={title} 
  description={description} 
  canonicalURL={canonicalURL} 
/>

<OpenGraph 
  title={title} 
  description={description} 
  image={image} 
  url={canonicalURL}
  type={type} 
/>

<TwitterCard 
  title={title} 
  description={description} 
  image={image} 
  cardType={twitterCardType} 
/>