---
import type { TwitterCardProps } from './types';

interface Props extends TwitterCardProps {
  cardType?: 'summary' | 'summary_large_image' | 'app' | 'player';
}

const {
  title,
  description,
  image,
  cardType = 'summary_large_image',
  creator,
  site
} = Astro.props;

const imageUrl = image
  ? (typeof image === 'string' && !image.startsWith('http')
    ? new URL(image, Astro.site || Astro.url.origin)
    : image)
  : undefined;
---

<meta name="twitter:card" content={cardType} data-seo="twitter:card" />
<meta name="twitter:title" content={title} data-seo="twitter:title" />
<meta name="twitter:description" content={description} data-seo="twitter:description" />
{imageUrl && <meta name="twitter:image" content={imageUrl.toString()} data-seo="twitter:image" />}
{site && <meta name="twitter:site" content={site} data-seo="twitter:site" />}
{creator && <meta name="twitter:creator" content={creator} data-seo="twitter:creator" />}
<slot name="twitter" />
<slot />