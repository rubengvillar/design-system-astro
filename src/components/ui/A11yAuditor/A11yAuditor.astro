---
// src/components/ui/A11yAuditor/A11yAuditor.astro
interface Props {
  position?: 'bottom-right' | 'bottom-left' | 'top-right' | 'top-left';
  label?: string;
}

const { 
  position = 'bottom-right', 
  label = 'Auditar accesibilidad' 
} = Astro.props;

const positionClasses = {
  'bottom-right': 'bottom-4 right-4',
  'bottom-left': 'bottom-4 left-4',
  'top-right': 'top-4 right-4',
  'top-left': 'top-4 left-4'
};
---

<a11y-auditor
  data-position={position}
  class:list={[
    "fixed z-[9999] pointer-events-none flex flex-col items-end gap-2",
    positionClasses[position]
  ]}
>
  <button
    data-trigger
    class="pointer-events-auto bg-primary text-primary-foreground rounded-full p-3 shadow-lg hover:scale-110 transition-transform flex items-center justify-center focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
    aria-label={label}
    title={label}
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/>
    </svg>
  </button>

  <div
    data-panel
    class="hidden pointer-events-auto bg-background border border-border shadow-2xl rounded-2xl w-80 md:w-96 max-h-[70vh] flex flex-col overflow-hidden animate-in slide-in-from-bottom-4 duration-300"
    role="dialog"
    aria-labelledby="a11y-auditor-title"
  >
    <header class="flex items-center justify-between p-4 border-b bg-muted/30 backdrop-blur-md">
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 rounded-full bg-primary animate-pulse"></div>
        <h3 id="a11y-auditor-title" class="font-bold text-sm uppercase tracking-wider">Auditoría A11y</h3>
      </div>
      <button data-close class="text-muted-foreground hover:text-foreground transition-colors p-1 rounded-md hover:bg-muted" aria-label="Cerrar panel">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </header>

    <div data-content class="flex-1 overflow-y-auto p-4 custom-scrollbar">
      <div class="flex flex-col items-center justify-center py-8 text-center space-y-3">
        <div class="p-3 bg-primary/5 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-emphasis"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
        </div>
        <p class="text-sm font-medium">Listo para analizar el DOM</p>
        <button data-run class="text-xs px-4 py-2 bg-primary text-primary-foreground rounded-lg font-bold hover:opacity-90 transition-opacity">
          Ejecutar Escaneo
        </button>
      </div>
    </div>

    <footer class="p-3 border-t bg-muted/10 text-[10px] text-muted-foreground flex justify-between items-center">
      <span>Powered by axe-core</span>
      <span data-status>Esperando...</span>
    </footer>
  </div>
</a11y-auditor>

<style is:global>
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: hsl(var(--muted));
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: hsl(var(--muted-foreground) / 0.5);
  }
  
  /* Highlight effect */
  @keyframes a11y-highlight {
    0% { outline: 4px solid hsl(var(--primary)); outline-offset: 4px; box-shadow: 0 0 0 100vmax rgba(0,0,0,0.3); }
    100% { outline: 0px solid transparent; outline-offset: 0px; box-shadow: 0 0 0 0px transparent; }
  }
  .a11y-node-highlight {
    z-index: 10000 !important;
    position: relative !important;
    animation: a11y-highlight 3s ease-out forwards;
    scroll-margin: 100px;
  }
</style>

<script>
  class A11yAuditor extends HTMLElement {
    private isAnalyzing = false;
    private axe: any = null;

    async connectedCallback() {
      const trigger = this.querySelector('[data-trigger]');
      const panel = this.querySelector('[data-panel]');
      const closeBtn = this.querySelector('[data-close]');
      const runBtn = this.querySelector('[data-run]');
      const content = this.querySelector('[data-content]');
      const status = this.querySelector('[data-status]');

      trigger?.addEventListener('click', () => {
        const isHidden = panel?.classList.toggle('hidden');
        if (!isHidden && !this.axe) {
          this.loadAxe();
        }
      });

      closeBtn?.addEventListener('click', () => {
        panel?.classList.add('hidden');
      });

      runBtn?.addEventListener('click', () => this.runAudit());
      // Delegated event for re-run button in results
      this.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('[data-run-again]')) {
          this.runAudit();
        }
      });
    }

    async loadAxe() {
      const status = this.querySelector('[data-status]');
      if (status) status.textContent = 'Cargando motor...';
      try {
        // Intentamos cargar la versión local de npm
        // @ts-ignore
        const module = await import('axe-core');
        this.axe = module.default || module;
        
        // axe-core a veces se inyecta en window
        if (!this.axe && (window as any).axe) {
          this.axe = (window as any).axe;
        }

        if (this.axe) {
          if (status) status.textContent = 'Motor listo (local)';
          return;
        }
        throw new Error('Axe not found in module');
      } catch (err) {
        console.warn('Local axe-core failed, using CDN fallback', err);
        try {
          // Fallback a CDN con vite-ignore para evitar que Vite intente procesar la URL
          // @ts-ignore
          await import(/* @vite-ignore */ 'https://cdnjs.cloudflare.com/ajax/libs/axe-core/4.10.2/axe.min.js');
          this.axe = (window as any).axe;
          
          if (this.axe) {
            if (status) status.textContent = 'Motor listo (CDN)';
          } else {
            throw new Error('Axe not found in window after CDN load');
          }
        } catch (cdnErr) {
          console.error('All axe loading methods failed', cdnErr);
          if (status) status.textContent = 'Error de carga';
        }
      }
    }

    async runAudit() {
      if (this.isAnalyzing || !this.axe) return;
      
      const content = this.querySelector('[data-content]');
      const status = this.querySelector('[data-status]');
      
      this.isAnalyzing = true;
      if (status) status.textContent = 'Analizando...';
      if (content) {
        content.innerHTML = `
          <div class="flex flex-col items-center justify-center py-12 space-y-4">
            <div class="w-8 h-8 border-4 border-primary border-t-transparent rounded-full animate-spin"></div>
            <p class="text-sm text-muted-foreground animate-pulse">Análisis en curso...</p>
          </div>
        `;
      }

      try {
        // Use a timeout to allow the spinner to show
        await new Promise(resolve => setTimeout(resolve, 100));
        const results = await this.axe.run();
        this.renderResults(results);
        if (status) status.textContent = `Completado: ${results.violations.length} fallos`;
      } catch (err: any) {
        if (content) content.innerHTML = `<p class="text-destructive text-sm p-4 bg-destructive/10 rounded-lg">Error: ${err.message}</p>`;
        if (status) status.textContent = 'Error en análisis';
      } finally {
        this.isAnalyzing = false;
      }
    }

    renderResults(results: any) {
      const content = this.querySelector('[data-content]');
      if (!content) return;

      if (results.violations.length === 0) {
        content.innerHTML = `
          <div class="bg-green-500/10 border border-green-500/20 rounded-xl p-6 text-center space-y-3">
            <div class="inline-flex p-3 bg-green-500/20 rounded-full text-green-600 dark:text-green-400">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h4 class="font-bold text-green-700 dark:text-green-300">¡Perfecto!</h4>
            <p class="text-xs text-green-600/80 dark:text-green-400/80">No se detectaron violaciones de accesibilidad automáticas en esta página.</p>
            <button data-run-again class="text-xs font-bold text-primary-emphasis hover:underline pt-2">Volver a escanear</button>
          </div>
        `;
        return;
      }

      const totalIssues = results.violations.length;
      content.innerHTML = `
        <div class="flex items-center justify-between mb-4 px-1">
          <span class="text-xs font-bold text-destructive uppercase tracking-tight">${totalIssues} Violaciones detectadas</span>
          <button data-run-again class="text-[10px] bg-muted px-2 py-1 rounded hover:bg-muted/80 transition-colors">Refrescar</button>
        </div>
        <div class="space-y-4">
          ${results.violations.map((v: any, i: number) => this.renderViolation(v, i)).join('')}
        </div>
      `;

      // Setup interactions
      this.setupResultInteractions(content);
    }

    renderViolation(v: any, index: number) {
      const impactColors: Record<string, string> = {
        critical: 'text-red-500 bg-red-500/10 border-red-500/20',
        serious: 'text-orange-500 bg-orange-500/10 border-orange-500/20',
        moderate: 'text-yellow-600 bg-yellow-600/10 border-yellow-600/20',
        minor: 'text-blue-500 bg-blue-500/10 border-blue-500/20'
      };

      const colorClass = impactColors[v.impact] || impactColors.minor;

      return `
        <div class="group border border-border/50 rounded-xl overflow-hidden bg-card/50 hover:border-border transition-colors">
          <div class="p-3 flex gap-3 items-start">
            <span class="mt-0.5 px-1.5 py-0.5 rounded text-[8px] font-black uppercase border ${colorClass}">
              ${v.impact}
            </span>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-bold leading-tight mb-1">${v.help}</p>
              <p class="text-[11px] text-muted-foreground line-clamp-2 mb-2">${v.description}</p>
              
              <div class="flex items-center gap-2">
                <button 
                  data-toggle-nodes="${index}"
                  class="text-[10px] font-bold text-primary-emphasis flex items-center gap-1 hover:underline"
                >
                  ${v.nodes.length} elemento(s) afectado(s)
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                <a href="${v.helpUrl}" target="_blank" class="text-[10px] text-muted-foreground hover:text-foreground">Más info ↗</a>
              </div>
            </div>
          </div>
          
          <div id="nodes-${index}" class="hidden border-t bg-muted/20 divide-y divide-border/30">
            ${v.nodes.map((n: any, ni: number) => this.renderNode(n, ni)).join('')}
          </div>
        </div>
      `;
    }

    renderNode(node: any, index: number) {
      const selector = node.target.join(' ');
      const htmlSnippet = node.html.length > 150 ? node.html.substring(0, 150) + '...' : node.html;
      
      return `
        <div class="p-3 space-y-2">
          <div class="flex items-start justify-between gap-2">
            <code class="text-[9px] bg-muted p-1 rounded font-mono break-all flex-1 text-primary-emphasis">
              ${this.escapeHtml(selector)}
            </code>
            <button 
              data-inspect-node="${this.escapeAttr(selector)}"
              class="shrink-0 p-1.5 bg-primary text-primary-foreground rounded-md hover:opacity-90 transition-opacity"
              title="Localizar elemento"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </button>
          </div>
          
          <div class="bg-zinc-950 p-2 rounded-lg text-[9px] font-mono text-zinc-400 overflow-x-auto border border-white/5">
            ${this.escapeHtml(htmlSnippet)}
          </div>
          
          ${node.failureSummary ? `
            <div class="text-[10px] text-muted-foreground border-l-2 border-primary/30 pl-2 py-1 italic bg-primary/5">
              ${this.escapeHtml(node.failureSummary).replace(/\n/g, '<br>')}
            </div>
          ` : ''}
        </div>
      `;
    }

    setupResultInteractions(content: HTMLElement) {
      // Toggle nodes
      content.querySelectorAll('[data-toggle-nodes]').forEach(btn => {
        btn.addEventListener('click', () => {
          const index = (btn as HTMLElement).dataset.toggleNodes;
          const nodesList = content.querySelector(`#nodes-${index}`);
          const icon = btn.querySelector('svg');
          
          if (nodesList) {
            const isHidden = nodesList.classList.toggle('hidden');
            if (icon) icon.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
          }
        });
      });

      // Inspect nodes
      content.querySelectorAll('[data-inspect-node]').forEach(btn => {
        btn.addEventListener('click', () => {
          const selector = (btn as HTMLElement).dataset.inspectNode;
          if (!selector) return;
          
          try {
            const el = document.querySelector(selector);
            if (el) {
              // Smooth scroll to element
              el.scrollIntoView({ behavior: 'smooth', block: 'center' });
              
              // Apply highlight class
              el.classList.add('a11y-node-highlight');
              
              // Close panel if on mobile for better visibility
              if (window.innerWidth < 768) {
                this.querySelector('[data-panel]')?.classList.add('hidden');
              }
              
              // Remove highlight after animation
              setTimeout(() => {
                el.classList.remove('a11y-node-highlight');
              }, 3000);
            } else {
              alert('Elemento no encontrado en el DOM actual (puede ser dinámico)');
            }
          } catch (e) {
            console.error('Invalid selector', selector);
          }
        });
      });
    }

    escapeHtml(str: string) {
      if (!str) return '';
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    escapeAttr(str: string) {
      if (!str) return '';
      return str.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
  }

  if (!customElements.get('a11y-auditor')) {
    customElements.define('a11y-auditor', A11yAuditor);
  }
</script>
