---
import { classMerge } from "../../utils/classMerge";

interface Props {
  variant?: 'default' | 'error' | 'success' | 'warning';
  title?: string;
  class?: string;
  dismissible?: boolean; // <-- Nueva propiedad
}

const { 
  variant = 'default', 
  title, 
  class: className,
  dismissible = false 
} = Astro.props;

const styles = {
  default: "border-border bg-background text-foreground",
  // Añadimos colores adaptativos para el modo oscuro (dark:)
  error: "border-red-500/50 bg-red-50 text-red-900 dark:bg-red-900/10 dark:text-red-200 dark:border-red-900/50",
  success: "border-green-500/50 bg-green-50 text-green-900 dark:bg-green-900/10 dark:text-green-200 dark:border-green-900/50",
  warning: "border-yellow-500/50 bg-yellow-50 text-yellow-900 dark:bg-yellow-900/10 dark:text-yellow-200 dark:border-yellow-900/50",
};

// Generamos un ID único por si hay varias alertas y queremos cerrar una en específico
const alertId = `alert-${Math.random().toString(36).substring(2, 9)}`;
---

<div 
  id={alertId}
  role="alert" 
  class={classMerge(
    "relative w-full rounded-[var(--radius)] border p-4",
    // Magia de selectores: posiciona el SVG y empuja el texto a la derecha para que no choquen
    "[&>svg]:absolute [&>svg]:left-4 [&>svg]:top-4 [&>svg+div]:translate-y-[-3px] [&>svg~*]:pl-7",
    styles[variant],
    className
  )}
>
  <slot name="icon" />
  
  <div class="flex flex-col gap-1 pr-6">
    {title && <h5 class="font-medium leading-none tracking-tight">{title}</h5>}
    
    <div class="text-sm opacity-90 [&_p]:leading-relaxed">
      <slot /> 
    </div>
  </div>

  {dismissible && (
    <button
      type="button"
      class="absolute right-4 top-4 rounded-md opacity-70 transition-opacity hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-foreground focus:ring-offset-2 focus:ring-offset-background"
      aria-label="Cerrar alerta"
      onclick={`document.getElementById('${alertId}').style.display = 'none'`}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
      </svg>
    </button>
  )}
</div>