---
interface Props {
  variant?: 'default' | 'error' | 'success' | 'warning';
  title?: string;
  class?: string;
}

const { 
  variant = 'default', 
  title, 
  class: className 
} = Astro.props;

const styles = {
  default: "border-border bg-background text-foreground",
  error: "border-red-500/50 bg-red-50 text-red-900",
  success: "border-green-500/50 bg-green-50 text-green-900",
  warning: "border-yellow-500/50 bg-yellow-50 text-yellow-900",
};
---

<div 
  role="alert" 
  class:list={[
    "relative w-full rounded-[var(--radius)] border p-4 [&>svg]:absolute [&>svg]:left-4 [&>svg]:top-4",
    styles[variant],
    className
  ]}
>
  {title && <h5 class="mb-1 font-medium leading-none tracking-tight">{title}</h5>}
  <div class="text-sm [&_p]:leading-relaxed">
    <slot />
  </div>
</div>