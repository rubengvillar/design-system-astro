---
import Container from '../layouts/Container.astro';
import Separator from '../layouts/Separator.astro';

interface Props {
  class?: string;
  copyrightOwner?: string;
}

const { 
  class: className, 
  copyrightOwner = "Tu Nombre o Empresa" // Valor por defecto
} = Astro.props;

const year = new Date().getFullYear();
---

<footer class:list={["w-full py-10 bg-background border-t", className]}>
  <Container>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8">
      
      <div class="col-span-2 md:col-span-1 flex flex-col gap-2">
        <slot name="brand" />
      </div>

      <div class="col-span-2 md:col-span-3 grid grid-cols-2 md:grid-cols-3 gap-8">
        <slot name="links" />
      </div>
    </div>

    <Separator class="my-6" />

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-muted-foreground">
      <p class="text-center md:text-left">
        &copy; {year} {copyrightOwner}. Todos los derechos reservados.
      </p>
      
      <div class="flex gap-4">
        <slot name="bottom-links" />
      </div>
    </div>
  </Container>
</footer>