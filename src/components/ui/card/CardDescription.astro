---
import type { HTMLTag } from "astro/types";
import type { PolymorphicProps } from "../../../types/polymorphic";
import { classMerge } from "../../../utils/classMerge";

type Props<T extends HTMLTag = "p"> = PolymorphicProps<T>;

const { as: Tag = "p", class: className, ...rest } = Astro.props;
---

<Tag class={classMerge("text-sm text-muted-foreground", className)} {...rest}>
  <slot />
</Tag>
