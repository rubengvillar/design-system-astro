---
import type { HTMLTag } from "astro/types";
import type { PolymorphicProps } from "../../../types/polymorphic";
import { classMerge } from "../../../utils/classMerge";

type Props<T extends HTMLTag = "h3"> = PolymorphicProps<T>;

const { as: Tag = "h3", class: className, ...rest } = Astro.props;
---

<Tag
  class={classMerge("font-semibold leading-none tracking-tight", className)}
  {...rest}
>
  <slot />
</Tag>
