---
import { classMerge } from "../../../utils/classMerge";
import type { HTMLTag } from "astro/types";
import type { PolymorphicProps } from "../../types/polymorphic";
import { generateId } from "../../utils/id";

type Props<T extends HTMLTag = "div"> = PolymorphicProps<T> & {
  open?: boolean;
};

const { open = false, class: className, as: Tag = "div", ...rest } = Astro.props;
---

<ui-collapse
  data-open={open.toString()}
  class={classMerge("block w-full border-b border-border/50 last:border-0", className)}
  {...rest}
>
  <slot />
</ui-collapse>

<script>
  import { generateId } from "../../utils/id";

  class UiCollapse extends HTMLElement {
    private header: HTMLElement | null = null;
    private content: HTMLElement | null = null;

    constructor() {
      super();
    }

    connectedCallback() {
      this.header = this.querySelector('[data-collapse-header]');
      this.content = this.querySelector('[data-collapse-content]');
      
      if (!this.header || !this.content) return;

      // Link for A11y
      const id = this.id || generateId("collapse");
      const contentId = `${id}-content`;
      this.content.id = contentId;
      this.header.setAttribute('aria-controls', contentId);

      this.header.addEventListener('click', () => this.toggle());
      
      this.content.addEventListener('transitionend', (e) => {
        if (e.propertyName === 'height' && this.dataset.open === 'true') {
          if (this.content) this.content.style.height = 'auto';
        }
      });

      const initialOpen = this.dataset.open === 'true';
      this.updateState(initialOpen, true);
    }

    toggle() {
      const isOpen = this.dataset.open === 'true';
      this.dataset.open = (!isOpen).toString();
      this.updateState(!isOpen);
    }

    updateState(isOpen: boolean, isInitial = false) {
      if (!this.header || !this.content) return;
      
      const icon = this.header.querySelector('[data-collapse-icon]');
      
      if (isOpen) {
        this.content.classList.remove('invisible', 'pointer-events-none');
        this.content.setAttribute('aria-hidden', 'false');
        
        if (isInitial) {
          this.content.style.height = 'auto';
          this.content.style.opacity = '1';
        } else {
          this.content.style.height = '0px';
          this.content.offsetHeight; // reflow
          this.content.style.height = this.content.scrollHeight + 'px';
          this.content.style.opacity = '1';
        }
        
        if (icon) icon.classList.add('rotate-180');
        this.header.setAttribute('aria-expanded', 'true');
      } else {
        this.content.setAttribute('aria-hidden', 'true');
        if (!isInitial) {
          const currentHeight = this.content.offsetHeight;
          this.content.style.height = currentHeight + 'px';
          this.content.offsetHeight; // reflow
          this.content.style.height = '0px';
          this.content.style.opacity = '0';
        } else {
          this.content.style.height = '0px';
          this.content.style.opacity = '0';
        }
        
        if (isInitial) {
          this.content.classList.add('invisible', 'pointer-events-none');
        } else {
          this.content.classList.add('pointer-events-none');
          this.content.addEventListener('transitionend', () => {
            if (this.dataset.open === 'false' && this.content) {
              this.content.classList.add('invisible');
            }
          }, { once: true });
        }
        
        if (icon) icon.classList.remove('rotate-180');
        this.header.setAttribute('aria-expanded', 'false');
      }
    }
  }

  if (!customElements.get('ui-collapse')) {
    customElements.define('ui-collapse', UiCollapse);
  }
</script>

<style is:global>
  ui-collapse [data-collapse-content] {
    transition: height 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
    overflow: hidden;
  }
</style>
