---
import { classMerge } from "../../../utils/classMerge";
import type { HTMLTag } from "astro/types";
import type { PolymorphicProps } from "../../types/polymorphic";

type Props<T extends HTMLTag = "button"> = PolymorphicProps<T>;

const { class: className, as: Tag = "button", ...rest } = Astro.props;
---

<Tag
  data-collapse-header
  type={Tag === "button" ? "button" : undefined}
  aria-expanded="false"
  class={classMerge(
    "flex w-full items-center justify-between py-4 text-sm font-medium transition-all hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-sm",
    className
  )}
  {...rest}
>
  <slot />
  <svg
    data-collapse-icon
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-4 w-4 shrink-0 transition-transform duration-200"
  >
    <path d="m6 9 6 6 6-6"></path>
  </svg>
</Tag>
