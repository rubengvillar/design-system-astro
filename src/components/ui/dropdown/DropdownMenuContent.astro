---
import type { HTMLTag } from "astro/types";
import type { PolymorphicProps } from "../../../types/polymorphic";
import { classMerge } from "../../../utils/classMerge";

type Props<T extends HTMLTag = "div"> = PolymorphicProps<T>;

const { class: className, as: Tag = "div", ...rest } = Astro.props;
---

<Tag
  data-dropdown-content
  role="menu"
  aria-orientation="vertical"
  class={classMerge(
    "absolute top-full z-50 mt-2 hidden min-w-[8rem] flex-col overflow-hidden rounded-md border bg-popover p-1 text-popover-foreground shadow-md animate-in fade-in-80 slide-in-from-top-1",
    className
  )}
  {...rest}
>
  <slot />
</Tag>
