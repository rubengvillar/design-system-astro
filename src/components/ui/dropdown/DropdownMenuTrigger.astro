---
import type { HTMLTag } from "astro/types";
import type { PolymorphicProps } from "../../../types/polymorphic";
import { classMerge } from "../../../utils/classMerge";

type Props<T extends HTMLTag = "button"> = PolymorphicProps<T>;

const { class: className, as: Tag = "button", ...rest } = Astro.props;
---

<Tag
  data-dropdown-trigger
  aria-haspopup="true"
  aria-expanded="false"
  type={Tag === "button" ? "button" : undefined}
  class={classMerge("focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-sm", className)}
  {...rest}
>
  <slot />
</Tag>
