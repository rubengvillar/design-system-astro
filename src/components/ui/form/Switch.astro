---
import type { HTMLAttributes } from 'astro/types';
import { classMerge } from "../../../utils/classMerge";

interface Props extends HTMLAttributes<'input'> {
  size?: 'sm' | 'md' | 'lg';
}

const { size = 'md', class: className, ...rest } = Astro.props;

const sizes = {
  sm: 'w-8 h-4 after:h-3 after:w-3 after:top-[2px] after:left-[2px] peer-checked:after:translate-x-4',
  md: 'w-11 h-6 after:h-5 after:w-5 after:top-[2px] after:left-[2px] peer-checked:after:translate-x-5',
  lg: 'w-14 h-8 after:h-7 after:w-7 after:top-[2px] after:left-[2px] peer-checked:after:translate-x-6'
};
---

<label class={classMerge("relative inline-flex items-center cursor-pointer", className)}>
  <input type="checkbox" class="peer sr-only" {...rest} />
  <div class={classMerge(
    "bg-muted peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-ring peer-focus:ring-offset-2 peer-focus:ring-offset-background rounded-full peer peer-checked:bg-primary transition-colors duration-200 ease-in-out",
    "after:content-[''] after:absolute after:bg-background after:rounded-full after:transition-transform after:duration-200 after:ease-in-out",
    sizes[size]
  )}></div>
</label>


