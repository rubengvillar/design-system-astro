---
import type { HTMLAttributes } from 'astro/types';
import { classMerge } from "../../../utils/classMerge";

interface Props extends HTMLAttributes<'textarea'> {
  error?: boolean;
}

const { error, class: className, ...rest } = Astro.props;
---

<textarea
  class={classMerge(
    "flex min-h-[80px] w-full rounded-[var(--radius)] border border-[var(--input)] bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50",
    error ? "border-red-500 focus-visible:ring-red-500" : "focus-visible:ring-primary",
    className
  )}
  {...rest}
/>