---
import { classMerge } from "../../../utils/classMerge";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {}
const { class: className, ...rest } = Astro.props;
---

<div
  data-navbar-menu
  class={classMerge(
    "md:hidden grid grid-rows-[0fr] opacity-0 transition-all duration-300 ease-in-out w-full",
    className
  )}
  {...rest}
>
  <div class="overflow-hidden">
    <nav class="flex flex-col space-y-4 px-4 pb-6 pt-4 text-sm font-medium bg-background border-b">
      <slot />
    </nav>
  </div>
</div>
