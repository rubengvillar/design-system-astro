---
import { classMerge } from '../../../utils/classMerge';
import type { HTMLTag } from "astro/types";
import type { PolymorphicProps } from "../../../types/polymorphic";

type Props<T extends HTMLTag = "dl"> = PolymorphicProps<T>;

const { class: className, as: Tag = "dl", ...rest } = Astro.props;

const baseStyles = "flex flex-col-reverse gap-1 p-4 rounded-xl border border-border/50 bg-background/50 backdrop-blur-sm shadow-sm transition-all hover:shadow-md";
---

<Tag class={classMerge(baseStyles, className)} {...rest}>
  <slot />
</Tag>
