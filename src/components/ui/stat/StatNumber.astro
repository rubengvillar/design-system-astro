---
import { classMerge } from '../../../utils/classMerge';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'dd'> {}

const { class: className, ...rest } = Astro.props;

const baseStyles = "text-3xl font-bold tracking-tight text-foreground transition-transform duration-300 hover:scale-105 origin-left";
---

<dd class={classMerge(baseStyles, className)} {...rest}>
  <slot />
</dd>
