---
import type { HTMLTag } from "astro/types";
import type { PolymorphicProps } from "../../../types/polymorphic";
import { classMerge } from "../../../utils/classMerge";

type Props<T extends HTMLTag = "div"> = PolymorphicProps<T> & {
  defaultValue?: string;
};

const { defaultValue, class: className, as: Tag = "div", ...rest } = Astro.props;
---

<ui-tabs
  data-default={defaultValue}
  class={classMerge("block", className)}
  {...rest}
>
  <slot />
</ui-tabs>

<script>
  class UITabs extends HTMLElement {
    private triggers: HTMLElement[] = [];
    private panels: HTMLElement[] = [];

    connectedCallback() {
      // Delay initialization to ensure children are parsed
      setTimeout(() => this.init(), 0);
    }

    init() {
      this.triggers = Array.from(this.querySelectorAll('[role="tab"]'));
      this.panels = Array.from(this.querySelectorAll('[role="tabpanel"]'));
      
      const defaultValue = this.dataset.default;
      let initialTab = this.triggers.find(t => t.dataset.value === defaultValue) || this.triggers[0];

      this.triggers.forEach((trigger, index) => {
        trigger.addEventListener('click', () => this.activateTab(trigger));
        trigger.addEventListener('keydown', (e) => this.handleKeyDown(e, index));
      });

      if (initialTab) {
        this.activateTab(initialTab, false);
      }
    }

    activateTab(tab: HTMLElement, shouldFocus = true) {
      const value = tab.dataset.value;
      
      this.triggers.forEach(t => {
        const isSelected = t === tab;
        t.setAttribute('aria-selected', isSelected ? 'true' : 'false');
        t.setAttribute('tabindex', isSelected ? '0' : '-1');
        t.setAttribute('data-state', isSelected ? 'active' : 'inactive');
        if (isSelected && shouldFocus) t.focus();
      });

      this.panels.forEach(p => {
        const isSelected = p.dataset.value === value;
        p.setAttribute('data-state', isSelected ? 'active' : 'inactive');
        if (isSelected) {
          p.removeAttribute('hidden');
        } else {
          p.setAttribute('hidden', '');
        }
      });
    }

    handleKeyDown(e: KeyboardEvent, index: number) {
      let newIndex = index;

      switch (e.key) {
        case 'ArrowRight':
          newIndex = (index + 1) % this.triggers.length;
          break;
        case 'ArrowLeft':
          newIndex = (index - 1 + this.triggers.length) % this.triggers.length;
          break;
        case 'Home':
          newIndex = 0;
          break;
        case 'End':
          newIndex = this.triggers.length - 1;
          break;
        default:
          return;
      }

      e.preventDefault();
      this.activateTab(this.triggers[newIndex]);
    }
  }

  if (!customElements.get('ui-tabs')) {
    customElements.define('ui-tabs', UITabs);
  }
</script>
