---
import type { HTMLAttributes } from 'astro/types';
import { classMerge } from "../../../utils/classMerge";

interface Props extends HTMLAttributes<'div'> {
  content: string;
  position?: 'top' | 'bottom' | 'left' | 'right';
}

const { content, position = 'top', class: className, ...rest } = Astro.props;

const positionClasses = {
  top: 'bottom-full left-1/2 -translate-x-1/2 mb-2',
  bottom: 'top-full left-1/2 -translate-x-1/2 mt-2',
  left: 'right-full top-1/2 -translate-y-1/2 mr-2',
  right: 'left-full top-1/2 -translate-y-1/2 ml-2',
};
---

<div class={classMerge("group relative inline-block", className)} {...rest}>
  <slot />
  <div
    role="tooltip"
    class={classMerge(
      "pointer-events-none absolute z-50 whitespace-nowrap rounded-md bg-primary px-3 py-1.5 text-xs text-primary-foreground opacity-0 transition-opacity group-hover:opacity-100",
      positionClasses[position]
    )}
  >
    {content}
  </div>
</div>
