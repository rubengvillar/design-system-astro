---
import '../styles/globals.css';
import { 
  Navbar, 
  NavbarBrand, 
  NavbarContent, 
  NavbarMenuToggle, 
  NavbarMenu, 
  NavbarLink, 
  ThemeScript,
  ThemeToggle,
  Toaster,
  Collapse,
  CollapseHeader,
  CollapseContent,
  Footer,
  FooterBottom,
  SEO,
  A11yAuditor,
  type SEOProps
} from '@rubenvillar/design-system-astro';

interface Props extends SEOProps {
  title: string;
  description?: string;
}

const { 
  title, 
  description,
  image,
  canonicalURL,
  type,
  twitterCardType,
  locale,
  siteName
} = Astro.props;

    const categories = [
    {
      name: 'Fundamentos',
      items: [
        { name: 'Instalación', url: '/docs/installation' },
        { name: 'CLI', url: '/docs/cli' },
        { name: 'Typography', url: '/docs/typography' },
      { name: 'Layout', url: '/docs/layout' },
      { name: 'Collapse', url: '/docs/collapse' },
      { name: 'SEO', url: '/docs/seo' },
      { name: 'Theme', url: '/docs/theme' },
    ]
  },
  {
    name: 'Elementos UI',
    items: [
      { name: 'Button', url: '/docs/button' },
      { name: 'Badge', url: '/docs/badge' },
      { name: 'Avatar', url: '/docs/avatar' },
      { name: 'Image', url: '/docs/image' },
      { name: 'Skeleton', url: '/docs/skeleton' },
    ]
  },
  {
    name: 'Contenedores',
    items: [
      { name: 'Card', url: '/docs/card' },
      { name: 'Table', url: '/docs/table' },
      { name: 'Tabs', url: '/docs/tabs' },
      { name: 'Stat', url: '/docs/stat' },
    ]
  },
  {
    name: 'Formularios',
    items: [
      { name: 'Forms', url: '/docs/forms' },
      { name: 'Calendar', url: '/docs/calendar' },
    ]
  },
  {
    name: 'Navegación',
    items: [
      { name: 'Navbar', url: '/docs/navbar' },
      { name: 'Sidebar', url: '/docs/sidebar' },
      { name: 'Footer', url: '/docs/footer' },
    ]
  },
  {
    name: 'Superposiciones',
    items: [
      { name: 'Alert', url: '/docs/alert' },
      { name: 'Modal', url: '/docs/modal' },
      { name: 'Dropdown', url: '/docs/dropdown' },
      { name: 'Toast', url: '/docs/toast' },
      { name: 'Tooltip', url: '/docs/tooltip' },
      { name: 'Notification', url: '/docs/notification' },
    ]
  },
  {
    name: 'Animaciones',
    items: [
      { name: 'Blur Fade', url: '/docs/animations/blur-fade' },
      { name: 'Hover Lift', url: '/docs/animations/hover-lift' },
      { name: 'Marquee', url: '/docs/animations/marquee' },
      { name: 'Reveal', url: '/docs/animations/reveal' },
      { name: 'Spinner', url: '/docs/animations/spinner' },
      { name: 'Text Reveal', url: '/docs/animations/text-reveal' },
      { name: 'Typewriter', url: '/docs/animations/typewriter' },
    ]
  }
];

const currentPath = Astro.url.pathname;
---

<html lang="es">
  <head>
    <SEO
      title={`${title} | Design System Docs`}
      description={description}
      image={image}
      canonicalURL={canonicalURL || Astro.url.href}
      type={type}
      twitterCardType={twitterCardType}
      locale={locale}
      siteName={siteName || 'Design System Docs'}
    />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    
    <ThemeScript />
    
    <style is:global>
      :root {
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        --font-display: 'Outfit', system-ui, -apple-system, sans-serif;
      }
      
      body {
        font-family: var(--font-sans);
      }
      
      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-display);
      }

      .mesh-bg {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: -1;
        background-color: hsl(var(--background));
        background-image: 
          radial-gradient(at 0% 0%, hsla(var(--primary) / 0.15) 0px, transparent 50%),
          radial-gradient(at 100% 0%, hsla(280 100% 70% / 0.1) 0px, transparent 50%),
          radial-gradient(at 100% 100%, hsla(var(--primary) / 0.1) 0px, transparent 50%),
          radial-gradient(at 0% 100%, hsla(280 100% 70% / 0.05) 0px, transparent 50%);
      }

      .active-link {
        color: hsl(var(--primary));
        font-weight: 600;
        background-color: hsla(var(--primary) / 0.1);
        position: relative;
      }

      .active-link::before {
        content: '';
        position: absolute;
        left: 0;
        top: 20%;
        bottom: 20%;
        width: 3px;
        background-color: hsl(var(--primary));
        border-radius: 0 4px 4px 0;
      }

      /* Custom scrollbar for sidebar */
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }
      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </head>
  <body class="min-h-screen text-foreground flex flex-col selection:bg-primary/30">
    <div class="mesh-bg"></div>
    
    <div class="sticky top-0 z-50 glass">
      <Navbar>
        <div class="container mx-auto flex h-16 items-center justify-between px-6">
          <NavbarBrand>
            <a href="/" class="font-extrabold text-2xl tracking-tighter hover:text-primary transition-colors">
              System<span class="text-primary">Docs</span>
            </a>
          </NavbarBrand>
          
          <NavbarContent aria-label="Navegación principal">
            <NavbarLink href="/">Inicio</NavbarLink>
            <NavbarLink href="/docs/button">Componentes</NavbarLink>
            <a href="https://github.com/rubengvillar/design-system-astro" target="_blank" class="text-sm font-medium hover:text-primary transition-colors px-3 py-2">GitHub</a>
            <ThemeToggle />
          </NavbarContent>

          <div class="flex items-center gap-2 md:hidden">
            <ThemeToggle />
            <NavbarMenuToggle />
          </div>
        </div>

        <NavbarMenu aria-label="Navegación móvil">
          <div class="flex flex-col gap-4 py-8">
            <NavbarLink href="/" class="text-xl font-bold">Inicio</NavbarLink>
            <NavbarLink href="/docs/installation" class="text-xl font-bold">Documentación</NavbarLink>
            <a href="https://github.com/rubengvillar/design-system-astro" target="_blank" class="text-xl font-bold text-muted-foreground hover:text-primary transition-colors">GitHub</a>
          </div>
        </NavbarMenu>
      </Navbar>
    </div>

    <div class="container mx-auto flex-1 items-start md:grid md:grid-cols-[260px_minmax(0,1fr)] md:gap-8 lg:grid-cols-[280px_minmax(0,1fr)] lg:gap-12 px-6 py-8">
      
      <aside class="fixed top-20 z-30 -ml-2 hidden h-[calc(100vh-6rem)] w-full shrink-0 md:sticky md:block overflow-y-auto py-4 pr-6 scrollbar-hide">
        <div class="space-y-2">
          {categories.map((category) => {
            const isCategoryActive = category.items.some(item => item.url === currentPath);
            return (
              <Collapse open={isCategoryActive}>
                <CollapseHeader class="px-2 py-3 text-xs font-bold uppercase tracking-widest text-muted-foreground hover:text-foreground transition-colors">
                  {category.name}
                </CollapseHeader>
                <CollapseContent>
                  <nav class="grid gap-1 px-1 border-l-2 border-border/30 ml-2" aria-label="Navegación de documentación">
                    {category.items.map((item) => (
                      <a 
                        href={item.url} 
                        class:list={[
                          "flex w-full items-center rounded-lg px-3 py-2 text-sm transition-all hover:bg-primary/5 hover:text-primary",
                          currentPath === item.url ? "active-link" : "text-muted-foreground"
                        ]}
                      >
                        {item.name}
                      </a>
                    ))}
                  </nav>
                </CollapseContent>
              </Collapse>
            );
          })}
        </div>
      </aside>

      <main class="relative py-6 animate-in fade-in slide-in-from-bottom-4 duration-700">
        <div class="mx-auto w-full min-w-0 max-w-4xl">
          
          <!-- Mobile Sidebar (Categorized) -->
          <div class="md:hidden mb-8">
            <Collapse>
              <CollapseHeader class="flex items-center gap-2 px-4 py-3 bg-secondary/30 rounded-xl border border-border/50 text-primary font-semibold">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9h18"/><path d="M3 15h18"/><path d="M3 21h18"/><path d="M3 3h18"/></svg>
                Menú de Componentes
              </CollapseHeader>
              <CollapseContent class="mt-2 bg-background border border-border/50 rounded-xl overflow-hidden">
                <div class="p-2 space-y-1">
                  {categories.map((category) => {
                    const isCategoryActive = category.items.some(item => item.url === currentPath);
                    return (
                      <Collapse open={isCategoryActive}>
                        <CollapseHeader class="px-3 py-2 text-xs font-bold uppercase tracking-widest text-muted-foreground">
                          {category.name}
                        </CollapseHeader>
                        <CollapseContent>
                          <nav class="grid gap-1 px-1 border-l-2 border-border/30 ml-4 mb-2" aria-label={`Navegación móvil de ${category.name}`}>
                            {category.items.map((item) => (
                              <a 
                                href={item.url} 
                                class:list={[
                                  "flex w-full items-center rounded-lg px-3 py-2 text-sm transition-all",
                                  currentPath === item.url ? "text-primary font-semibold bg-primary/5" : "text-muted-foreground"
                                ]}
                              >
                                {item.name}
                              </a>
                            ))}
                          </nav>
                        </CollapseContent>
                      </Collapse>
                    );
                  })}
                </div>
              </CollapseContent>
            </Collapse>
          </div>

          <div class="mb-10">
            <h1 class="text-4xl font-extrabold tracking-tight lg:text-6xl mb-4 bg-gradient-to-br from-foreground to-foreground/50 bg-clip-text text-transparent">
              {title}
            </h1>
            {description && <p class="text-xl text-muted-foreground leading-relaxed max-w-2xl">{description}</p>}
          </div>
          
          <div class="prose prose-zinc dark:prose-invert max-w-none">
            <slot />
          </div>
          
        </div>
      </main>
    </div>

    <Footer class="mt-20 border-t border-border/50 bg-background/50 backdrop-blur-md">
      <div class="container mx-auto px-6">
        <FooterBottom>
          <p class="text-sm text-muted-foreground">
            &copy; {new Date().getFullYear()} @rubenvillar/design-system-astro. 
            Creado por <a href="https://rubenvillar.vercel.app" target="_blank" class="text-primary hover:underline font-medium">Ruben Villar</a>.
          </p>
        </FooterBottom>
      </div>
    </Footer>

    <aside aria-label="Utilidades del sistema">
      <Toaster />
      <A11yAuditor />
    </aside>
  </body>
</html>
