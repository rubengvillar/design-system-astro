---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import { HoverLift, Card, CardContent } from '@rubenvillar/design-system-astro';
---

<DocsLayout title="Hover Lift" description="Efecto de elevación interactivo al pasar el cursor.">
  <section class="space-y-6">
    <div>
      <p class="text-muted-foreground mb-4">
        El componente <code>&lt;HoverLift /&gt;</code> envuelve a cualquier otro componente para darle un sutil efecto de elevación (transform) y sombra al hacer hover. Mejora la interactividad de tarjetas y botones.
      </p>
    </div>

    <div class="space-y-4">
      <h3 class="text-xl font-bold">Ejemplos</h3>
      
      <div class="grid gap-6 md:grid-cols-3">
        <HoverLift scale="1.02" shadow="md">
          <Card>
            <CardContent class="p-6 text-center">Elevación sutil</CardContent>
          </Card>
        </HoverLift>

        <HoverLift scale="1.05" shadow="xl">
          <Card>
            <CardContent class="p-6 text-center">Elevación pronunciada</CardContent>
          </Card>
        </HoverLift>

        <HoverLift shadow="none">
          <Card>
            <CardContent class="p-6 text-center">Solo elevación sin sombra</CardContent>
          </Card>
        </HoverLift>
      </div>
    </div>
  </section>
</DocsLayout>
