---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import { Marquee, Badge } from '@rubenvillar/design-system-astro';
---

<DocsLayout title="Marquee" description="Carrusel infinito de desplazamiento horizontal.">
  <section class="space-y-6">
    <div>
      <p class="text-muted-foreground mb-4">
        El componente <code>&lt;Marquee /&gt;</code> crea una animación de desplazamiento continuo sin requerir JavaScript, ideal para banners de anuncios, carruseles de logotipos de clientes o tecnologías.
      </p>
    </div>

    <div class="space-y-4">
      <h3 class="text-xl font-bold">Ejemplos</h3>
      
      <div class="space-y-8">
        <div>
          <h4 class="text-sm font-semibold mb-2">Desplazamiento Normal</h4>
          <Marquee gap="2rem" class="py-4 border-y">
            <Badge variant="outline" class="text-lg px-4 py-2">React</Badge>
            <Badge variant="outline" class="text-lg px-4 py-2">Astro</Badge>
            <Badge variant="outline" class="text-lg px-4 py-2">TailwindCSS</Badge>
            <Badge variant="outline" class="text-lg px-4 py-2">TypeScript</Badge>
            <Badge variant="outline" class="text-lg px-4 py-2">Node.js</Badge>
          </Marquee>
        </div>

        <div>
          <h4 class="text-sm font-semibold mb-2">Dirección Inversa y Pausa al Hover</h4>
          <Marquee direction="right" speed="slow" pauseOnHover class="py-4 border-y bg-muted/30">
            <span class="text-2xl font-bold">🔥 Novedades v2.0</span>
            <span class="text-2xl font-bold text-muted-foreground">/</span>
            <span class="text-2xl font-bold">⚡ Componentes Rápidos</span>
            <span class="text-2xl font-bold text-muted-foreground">/</span>
            <span class="text-2xl font-bold">✨ Animaciones Fluidas</span>
            <span class="text-2xl font-bold text-muted-foreground">/</span>
          </Marquee>
        </div>
      </div>
    </div>

    <div class="space-y-4 mt-8">
      <h3 class="text-xl font-bold">Propiedades (Props)</h3>
      <div class="relative w-full overflow-auto">
        <table class="w-full caption-bottom text-sm border-collapse border">
          <thead class="[&_tr]:border-b bg-muted/50">
            <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground border-r">Propiedad</th>
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground border-r">Tipo</th>
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground border-r">Por defecto</th>
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Descripción</th>
            </tr>
          </thead>
          <tbody class="[&_tr:last-child]:border-0">
            <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
              <td class="p-4 align-middle border-r"><code>direction</code></td>
              <td class="p-4 align-middle border-r"><code>'left' | 'right'</code></td>
              <td class="p-4 align-middle border-r"><code>'left'</code></td>
              <td class="p-4 align-middle">Hacia dónde se mueve el carrusel.</td>
            </tr>
            <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
              <td class="p-4 align-middle border-r"><code>speed</code></td>
              <td class="p-4 align-middle border-r"><code>'slow' | 'normal' | 'fast' | number</code></td>
              <td class="p-4 align-middle border-r"><code>'normal'</code></td>
              <td class="p-4 align-middle">Velocidad (o tiempo en segundos de duración).</td>
            </tr>
            <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
              <td class="p-4 align-middle border-r"><code>pauseOnHover</code></td>
              <td class="p-4 align-middle border-r"><code>boolean</code></td>
              <td class="p-4 align-middle border-r"><code>false</code></td>
              <td class="p-4 align-middle">Si es true, pausa la animación al pasar el cursor.</td>
            </tr>
            <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
              <td class="p-4 align-middle border-r"><code>gap</code></td>
              <td class="p-4 align-middle border-r"><code>string</code></td>
              <td class="p-4 align-middle border-r"><code>'1rem'</code></td>
              <td class="p-4 align-middle">Espaciado entre elementos hijos.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</DocsLayout>
