---
import DocsLayout from '../../layouts/DocsLayout.astro';
import * as DesignSystem from '@rubenvillar/design-system-astro';
const { Avatar: AvatarComponent, Typography, Grid } = DesignSystem;
---

<DocsLayout title="Avatar">
  <Typography variant="p" class="mb-8 text-muted-foreground">
    Componente visual para mostrar imágenes de perfil, logotipos o iniciales con soporte de fallback automático.
  </Typography>

  <section class="space-y-8">
    <div>
      <Typography variant="h3" class="mb-4">Tamaños</Typography>
      <div class="flex items-end gap-4 p-6 border rounded-xl bg-card">
        <AvatarComponent size="sm" fallback="SM" />
        <AvatarComponent size="md" fallback="MD" />
        <AvatarComponent size="lg" fallback="LG" />
        <AvatarComponent size="xl" fallback="XL" />
      </div>
    </div>

    <div>
      <Typography variant="h3" class="mb-4">Con Imagen y Fallback</Typography>
      <div class="flex gap-4 p-6 border rounded-xl bg-card">
        <AvatarComponent 
          src="https://github.com/shadcn.png" 
          alt="@shadcn" 
        />
        <AvatarComponent 
          src="invalid-link" 
          alt="Ruben Villar" 
          fallback="RV"
        />
        <AvatarComponent fallback="JD" class="bg-primary/10 text-primary-emphasis" />
      </div>
    </div>
  </section>
</DocsLayout>
