---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../playground-components/ComponentPreview.astro';
import { Navbar, NavbarBrand, NavbarContent, NavbarMenuToggle, NavbarMenu, NavbarLink, Typography } from '@rubenvillar/design-system-astro';

// 1. Código del Navbar Básico
const basicCode = `<Navbar>
  <div class="w-full max-w-screen-xl mx-auto px-4 md:px-8 flex h-14 items-center justify-between">
    <NavbarBrand>
      <a href="/" class="font-bold text-xl tracking-tight">BrandLogo</a>
    </NavbarBrand>
    
    <div class="flex items-center gap-6">
      <NavbarContent>
        <NavbarLink href="/features">Características</NavbarLink>
        <NavbarLink href="/pricing">Precios</NavbarLink>
        <NavbarLink href="/about">Nosotros</NavbarLink>
      </NavbarContent>
      <NavbarMenuToggle />
    </div>
  </div>

  <NavbarMenu>
    <NavbarLink href="/features">Características</NavbarLink>
    <NavbarLink href="/pricing">Precios</NavbarLink>
    <NavbarLink href="/about">Nosotros</NavbarLink>
  </NavbarMenu>
</Navbar>`;
---

<DocsLayout title="Navbar">
  <Typography variant="lead" class="mb-8 text-muted-foreground">
    Una cabecera de navegación responsiva utilizando componentes puramente modulares.
  </Typography>

  <ComponentPreview title="Navegación Básica" code={basicCode}>
    <div class="w-full flex flex-col rounded-xl border bg-background overflow-hidden shadow-sm">
      <Navbar>
        <div class="w-full max-w-screen-xl mx-auto px-4 md:px-8 flex h-14 items-center justify-between">
          <NavbarBrand>
            <a href="#home" class="font-bold text-xl tracking-tight">BrandLogo</a>
          </NavbarBrand>
          
          <div class="flex items-center gap-6">
            <NavbarContent>
              <NavbarLink href="#features">Características</NavbarLink>
              <NavbarLink href="#pricing">Precios</NavbarLink>
              <NavbarLink href="#about">Nosotros</NavbarLink>
            </NavbarContent>
            <NavbarMenuToggle />
          </div>
        </div>

        <NavbarMenu>
          <NavbarLink href="#features">Características</NavbarLink>
          <NavbarLink href="#pricing">Precios</NavbarLink>
          <NavbarLink href="#about">Nosotros</NavbarLink>
        </NavbarMenu>
      </Navbar>
      
      <div class="flex-1 bg-muted/30 p-8 flex items-center justify-center min-h-[150px]">
        <p class="text-sm text-muted-foreground">Contenido de la página</p>
      </div>
    </div>
  </ComponentPreview>
</DocsLayout>
