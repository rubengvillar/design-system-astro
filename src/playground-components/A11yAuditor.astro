---
// Componente de auditoría de accesibilidad para el playground
---

<div id="a11y-auditor-container" class="fixed bottom-4 right-4 z-[9999] pointer-events-none">
  <button
    id="a11y-audit-trigger"
    class="pointer-events-auto bg-primary text-primary-foreground rounded-full p-3 shadow-lg hover:scale-110 transition-transform flex items-center justify-center"
    title="Ejecutar auditoría A11y"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
  </button>

  <div
    id="a11y-results-panel"
    class="hidden pointer-events-auto mt-2 bg-background border border-border shadow-2xl rounded-xl w-80 max-h-[60vh] overflow-y-auto p-4 animate-in slide-in-from-bottom-4"
  >
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-bold text-lg">Auditoría A11y</h3>
      <button id="close-a11y-panel" class="text-muted-foreground hover:text-foreground">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    <div id="a11y-results-content" class="space-y-4">
      <p class="text-sm text-muted-foreground">Ejecutando escaneo...</p>
    </div>
  </div>
</div>

<script>
  // @ts-ignore
  import('https://cdnjs.cloudflare.com/ajax/libs/axe-core/4.7.2/axe.min.js').then(() => {
    const trigger = document.getElementById('a11y-audit-trigger');
    const panel = document.getElementById('a11y-results-panel');
    const closeBtn = document.getElementById('close-a11y-panel');
    const content = document.getElementById('a11y-results-content');

    trigger?.addEventListener('click', async () => {
      panel?.classList.toggle('hidden');
      if (!panel?.classList.contains('hidden')) {
        runAudit();
      }
    });

    closeBtn?.addEventListener('click', () => {
      panel?.classList.add('hidden');
    });

    async function runAudit() {
      if (!content) return;
      content.innerHTML = '<p class="text-sm animate-pulse">Analizando DOM...</p>';
      
      // @ts-ignore
      const results = await axe.run();
      
      if (results.violations.length === 0) {
        content.innerHTML = `
          <div class="bg-green-500/10 border border-green-500/20 rounded-lg p-3 text-green-600 dark:text-green-400">
            <p class="font-semibold text-sm flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              ¡Sin violaciones críticas!
            </p>
          </div>
        `;
      } else {
        content.innerHTML = `
          <p class="text-xs font-medium text-destructive mb-2">Se encontraron ${results.violations.length} problemas:</p>
          ${results.violations.map((v: any) => `
            <div class="border-l-2 border-destructive pl-3 py-1">
              <p class="text-sm font-bold">${v.help}</p>
              <p class="text-xs text-muted-foreground mt-1">${v.description}</p>
              <span class="inline-block mt-2 px-2 py-0.5 bg-destructive/10 text-destructive text-[10px] rounded uppercase font-bold">
                ${v.impact}
              </span>
            </div>
          `).join('')}
        `;
      }
    }
  });
</script>
