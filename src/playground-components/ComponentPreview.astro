---
import { Code } from 'astro:components'; // <-- Importamos el componente nativo de Astro

interface Props {
  title?: string;
  class?: string;
  code?: string; // <-- Nueva propiedad opcional
}

const { title, class: className, code } = Astro.props;
---

<div class="my-8 flex flex-col space-y-4">
  {title && <h3 class="text-lg font-semibold tracking-tight">{title}</h3>}
  
  <div class:list={[
    "relative flex min-h-[200px] w-full items-center justify-center rounded-lg border bg-background p-10",
    "bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] dark:bg-[radial-gradient(#1f2937_1px,transparent_1px)] [background-size:16px_16px]",
    className
  ]}>
    <div class="flex flex-wrap items-center justify-center gap-4 w-full">
      <slot />
    </div>
  </div>

  {code && (
    <div class="relative rounded-lg border bg-zinc-950 overflow-hidden">
      <div class="flex items-center justify-between px-4 py-2 border-b border-zinc-800 bg-zinc-900/50">
        <span class="text-xs font-medium text-zinc-400">Ejemplo del componente</span>
        {/* Aquí podrías añadir un botón de "Copiar" en el futuro si quisieras */}
      </div>
      <div class="p-4 overflow-x-auto text-sm [&_pre]:!bg-transparent [&_pre]:!m-0 [&_pre]:!p-0">
        <Code code={code} lang="astro" theme="github-dark" />
      </div>
    </div>
  )}
</div>