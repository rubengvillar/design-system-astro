{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@rubengvillar/design-system-astro": ["./src/index.ts"]
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "env.d.ts", "**/*.astro", ".astro/types.d.ts"]
}